# Qdrant
# Scripts default to http://localhost:6333 unless you pass --qdrant-url.
QDRANT_URL=http://localhost:6333
# Use this as your documented/default collection name. CLI tools and the UI still
# take the collection from flags or sidebar input rather than auto-reading this.
QDRANT_COLLECTION=medical_research_chunks_v1

# Embeddings
# EMBEDDING_PROVIDER must be "openai" or "azure_openai".
EMBEDDING_PROVIDER=azure_openai
# Required for CLI retrieval/ingestion scripts unless OPENAI_API_KEY is used as
# the fallback for OpenAI embeddings.
EMBEDDING_API_KEY=your-embedding-api-key
# For OpenAI, this is the embedding model name. For Azure OpenAI, this is the
# embedding deployment name.
EMBEDDING_MODEL=text-embedding-3-large
# Set to 0 to use the provider default output size when supported.
EMBEDDING_DIMENSIONS=1024

# Azure OpenAI embeddings
# Required when EMBEDDING_PROVIDER=azure_openai.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
# Keep these as explicit values if you load `.env` through a shell script or
# PowerShell helper; `${...}` references are not expanded by the repo itself.
EMBEDDING_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
EMBEDDING_AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI API key
# Optional for Azure embeddings when EMBEDDING_API_KEY is set.
# Used as the fallback for OpenAI embeddings and by default for answer synthesis.
OPENAI_API_KEY=

# Optional answer synthesis defaults
# For OpenAI, this is the chat model name. For Azure OpenAI, this is the chat
# deployment name used by the Streamlit UI.
OPENAI_MODEL=gpt-4o-mini
