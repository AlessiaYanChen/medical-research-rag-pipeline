# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medical_research_chunks_v1

# Embeddings
EMBEDDING_PROVIDER=azure_openai
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024

# Azure OpenAI embeddings
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
EMBEDDING_AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
EMBEDDING_AZURE_OPENAI_API_VERSION=${AZURE_OPENAI_API_VERSION}

# Optional OpenAI-compatible fallback
OPENAI_API_KEY=

# Optional LLM answer synthesis
OPENAI_MODEL=gpt-4.1
